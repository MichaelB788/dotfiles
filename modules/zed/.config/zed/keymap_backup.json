// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      // Save all files (Zed saves one at a time; this saves the active buffer)
      "ctrl-s": "workspace::Save",

      // Splits
      "space s v": "pane::SplitRight",
      "space s h": "pane::SplitDown",

      // Pane navigation
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],

      // Tab navigation
      "shift-l": "pane::ActivateNextItem",
      "shift-h": "pane::ActivatePreviousItem",

      // New tab
      "space t n": "workspace::NewFile",

      // Diagnostics
      "space x x": "diagnostics::Deploy",
      "space o f": "editor::Hover", // closest to open_float (shows inline diagnostics/hover)

      // LSP
      "g d": "editor::GoToDefinition",
      "space r n": "editor::Rename",
      "space l f": "editor::Format",
      "space c a": "editor::ToggleCodeActions",

      // File/search picker
      "space f": "file_finder::Toggle",
      "space g": "pane::DeploySearch", // closest to grep_live
      "space h": "zed::OpenDocs", // no direct help picker; this opens Zed docs

      // Terminal toggle
      "ctrl-t": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": "terminal_panel::ToggleFocus",
    },
  },
]
